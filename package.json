{
  "name": "playwright-e2e-framework",
  "version": "1.0.0",
  "description": "Production-grade E2E automation framework using Playwright and TypeScript",
  "main": "index.js",
  "scripts": {
    "test": "npx playwright test",
    "test:custom": "node scripts/run-test.js",
    "test:suite": "npx playwright test src/tests/web/suite",
    "test:web": "npx playwright test --project=chromium",
    "test:api": "npx playwright test --project=api",
    "test:mobile": "npx playwright test --project='Mobile Chrome' --project='Mobile Safari'",
    "test:desktop": "npx playwright test --project=electron",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "report": "npx playwright show-report",
    "allure:generate": "npx allure generate allure-results -o allure-report",
    "allure:open": "npx allure open allure-report"
  },
  "keywords": [
    "playwright",
    "typescript",
    "automation",
    "testing",
    "e2e",
    "api-testing",
    "mobile-emulation"
  ],
  "author": "Senior QA Automation Engineer",
  "license": "ISC",
  "devDependencies": {
    "@faker-js/faker": "^8.4.1",
    "@playwright/test": "^1.43.1",
    "@types/node": "^20.12.7",
    "@types/pg": "^8.20.0",
    "@typescript-eslint/eslint-plugin": "^7.7.0",
    "@typescript-eslint/parser": "^7.7.0",
    "allure-playwright": "^3.0.0-beta.2",
    "cross-env": "^10.1.0",
    "dotenv": "^16.4.5",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "prettier": "^3.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5",
    "winston": "^3.13.0"
  },
  "dependencies": {
    "mysql2": "^3.22.2",
    "pg": "^8.20.0"
  }
}
